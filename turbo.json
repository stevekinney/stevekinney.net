{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "@stevekinney/scripts#content:build": {
      "inputs": [
        "content-build.ts",
        "content-paths.ts",
        "content-repository.ts",
        "sync-generated-browser-assets.ts",
        "../utilities/content-types.ts",
        "../utilities/frontmatter.ts",
        "../utilities/tailwind-playground.ts",
        "../../applications/website/src/lib/content-enhancements.ts",
        "../../applications/website/src/lib/copy-code-block-as-image.ts",
        "../../applications/website/src/lib/actions/enhance-code-blocks.ts",
        "../../applications/website/src/lib/actions/enhance-mermaid-diagrams.ts",
        "../../applications/website/src/lib/actions/enhance-tailwind-playgrounds.ts",
        "../../applications/website/src/lib/actions/enhance-tables.ts",
        "../../writing/**/*.md",
        "../../courses/**/*.md",
        "../../courses/*/index.toml"
      ],
      "outputs": [
        "../../applications/website/.generated/content-data.json",
        "../../applications/website/.generated/tailwind-playground-source.html",
        "../../applications/website/.generated/content-enhancements/**"
      ]
    },
    "@stevekinney/scripts#content:validate": {
      "dependsOn": ["@stevekinney/scripts#content:build"],
      "inputs": [
        "validate-content.ts",
        "content-build.ts",
        "content-paths.ts",
        "content-repository.ts",
        "../utilities/content-types.ts",
        "../utilities/frontmatter.ts",
        "../utilities/tailwind-playground.ts",
        "../../writing/**/*.md",
        "../../courses/**/*.md",
        "../../courses/*/index.toml"
      ]
    },
    "@stevekinney/scripts#content:images:check": {
      "inputs": [
        "run-with-sharp-runtime.ts",
        "validate-image-compatibility.ts",
        "../../image-manifest.json",
        "../../writing/**/*.{png,jpg,jpeg,svg,gif,avif,webp,mp4}",
        "../../courses/**/*.{png,jpg,jpeg,svg,gif,avif,webp,mp4}"
      ]
    },
    "@stevekinney/scripts#images:check": {
      "inputs": [
        "check-image-manifest.ts",
        "../../image-manifest.json",
        "../../writing/**/*.{png,jpg,jpeg,svg,gif,avif,webp,mp4}",
        "../../courses/**/*.{png,jpg,jpeg,svg,gif,avif,webp,mp4}"
      ]
    },
    "@stevekinney/scripts#images:sync": {
      "cache": false,
      "env": ["BLOB_READ_WRITE_TOKEN"]
    },
    "@stevekinney/scripts#test:unit": {
      "dependsOn": ["@stevekinney/scripts#content:build"],
      "inputs": [
        "content-repository.test.ts",
        "content-build.ts",
        "content-paths.ts",
        "content-repository.ts",
        "../utilities/content-types.ts",
        "../utilities/frontmatter.ts",
        "../utilities/tailwind-playground.ts",
        "../../writing/**/*.md",
        "../../courses/**/*.md",
        "../../courses/*/index.toml"
      ]
    },
    "@stevekinney/website#build": {
      "dependsOn": [
        "@stevekinney/scripts#content:build",
        "@stevekinney/scripts#content:images:check"
      ],
      "inputs": [
        "package.json",
        "src/**",
        "static/**",
        "svelte.config.js",
        "vite.config.ts",
        "tsconfig.json",
        "../../packages/components/**/*.{svelte,ts,js}",
        "../../packages/plugins/src/**/*.ts",
        "../../packages/utilities/**/*.ts",
        "../../image-manifest.json",
        ".generated/**",
        "!build/**",
        "!.svelte-kit/**",
        "!test-results/**",
        "!playwright-report/**",
        "!.vercel/**"
      ],
      "env": ["VERCEL"],
      "outputs": ["build/**", ".svelte-kit/output/**", ".vercel/output/**"]
    },
    "@stevekinney/website#build:stats": {
      "dependsOn": ["@stevekinney/website#build"],
      "env": ["BUNDLE_STATS"]
    },
    "@stevekinney/website#preview": {
      "dependsOn": ["@stevekinney/website#build"],
      "cache": false
    },
    "@stevekinney/website#dev": {
      "dependsOn": ["@stevekinney/scripts#content:build"],
      "cache": false,
      "persistent": true
    },
    "@stevekinney/website#sync": {},
    "@stevekinney/website#lint": {},
    "@stevekinney/website#check": {
      "dependsOn": ["@stevekinney/scripts#content:build"]
    },
    "@stevekinney/website#check:watch": {
      "dependsOn": ["@stevekinney/scripts#content:build"],
      "cache": false,
      "persistent": true
    },
    "@stevekinney/website#test": {
      "dependsOn": ["@stevekinney/website#test:integration", "@stevekinney/website#test:unit"]
    },
    "@stevekinney/website#test:integration": {
      "dependsOn": ["@stevekinney/website#build"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "@stevekinney/website#test:integration:dev": {
      "cache": false
    },
    "@stevekinney/website#test:unit": {
      "dependsOn": ["@stevekinney/scripts#content:build"]
    },
    "@stevekinney/website#test:storybook": {
      "dependsOn": ["@stevekinney/website#build-storybook"]
    },
    "@stevekinney/website#storybook": {
      "cache": false,
      "persistent": true
    },
    "@stevekinney/website#build-storybook": {},
    "@stevekinney/website#clean": {
      "cache": false
    }
  }
}
