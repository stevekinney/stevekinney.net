{
  "name": "@stevekinney/website",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@stevekinney/plugins": "workspace:*",
    "@stevekinney/utilities": "workspace:*"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=\"--import tsx --disable-warning=ExperimentalWarning\" node ../../node_modules/vite/bin/vite.js dev --port 4444",
    "build": "NODE_OPTIONS=\"--max-old-space-size=4096 --import tsx --disable-warning=ExperimentalWarning\" bun run ../../packages/scripts/run-with-sharp-runtime.ts node ../../node_modules/vite/bin/vite.js build && bun run ../../packages/scripts/sync-generated-browser-assets.ts",
    "build:stats": "BUNDLE_STATS=1 bun run build",
    "preview": "node ../../node_modules/vite/bin/vite.js preview",
    "test": "bun run test:integration && bun run test:unit",
    "sync": "NODE_OPTIONS=\"--import tsx --disable-warning=ExperimentalWarning\" ../../node_modules/.bin/svelte-kit sync",
    "check": "bun run sync && NODE_OPTIONS=\"--import tsx --disable-warning=ExperimentalWarning\" ../../node_modules/.bin/svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun run sync && ../../node_modules/.bin/svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --cache --check . && eslint --cache .",
    "clean": "rm -rf build .svelte-kit test-results .vite",
    "content:validate": "bun run ../../packages/scripts/validate-content.ts",
    "content:build": "bun run ../../packages/scripts/content-build.ts",
    "test:integration": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=ExperimentalWarning ../../node_modules/.bin/playwright test",
    "test:integration:dev": "PLAYWRIGHT_WEB_SERVER=0 env -u NO_COLOR NODE_OPTIONS=--disable-warning=ExperimentalWarning ../../node_modules/.bin/playwright test",
    "test:unit": "NODE_OPTIONS=\"--import tsx --disable-warning=ExperimentalWarning\" ../../node_modules/.bin/vitest run",
    "test:storybook": "../../node_modules/.bin/test-storybook",
    "storybook": "../../node_modules/.bin/storybook dev -p 6006",
    "build-storybook": "../../node_modules/.bin/storybook build"
  }
}
